# ═══════════════════════════════════════════════════════════════
# SARTHI v1.0 — ENVIRONMENT CONFIGURATION
# Copy to .env and fill in values for production deployment
# ═══════════════════════════════════════════════════════════════

# ── Infrastructure ────────────────────────────────────────────────
POSTGRES_USER=sarthi
POSTGRES_PASSWORD=sarthi
POSTGRES_DB=sarthi
POSTGRES_PORT=5433

REDPANDA_BROKERS=localhost:19092
QDRANT_URL=http://localhost:6333
QDRANT_PORT=6333

# ── Temporal ──────────────────────────────────────────────────────
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_QUEUE=sarthi-queue
# Production: use postgres backend (not memory)
TEMPORAL_DB=postgresql
TEMPORAL_DB_HOST=localhost
TEMPORAL_DB_PORT=5433
TEMPORAL_DB_USER=sarthi
TEMPORAL_DB_PASSWORD=sarthi

# ── Ollama / LLM ──────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_CHAT_MODEL=qwen3:0.6b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# ── DSPy ─────────────────────────────────────────────────────────
DSPY_LM_MODEL=ollama_chat/qwen3:0.6b
DSPY_LM_API_BASE=http://localhost:11434

# ── Telegram ─────────────────────────────────────────────────────
TELEGRAM_API_BASE=http://localhost:8085    # tg-mock in dev
TELEGRAM_BOT_TOKEN=123:TOKEN
TELEGRAM_CHAT_ID=42
TELEGRAM_USE_MOCK=true

# ── Langfuse (self-hosted observability) ─────────────────────────
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=pk-lf-local-dev
LANGFUSE_SECRET_KEY=sk-lf-local-dev
LANGFUSE_ENABLED=true

# ── Go API ────────────────────────────────────────────────────────
LISTEN_ADDR=:8080
RAZORPAY_WEBHOOK_SECRET=
BANK_WEBHOOK_SECRET=

# ── Python AI worker ─────────────────────────────────────────────
DATABASE_URL=postgresql://sarthi:sarthi@localhost:5433/sarthi
