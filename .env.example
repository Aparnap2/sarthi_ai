# IterateSwarm OS - Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git!
#
# =============================================================================
# Sarthi v4.2 — LLM Factory Configuration (PRIMARY)
# =============================================================================
# All LLM access goes through apps/ai/src/config/llm.py factory.
# NO direct AzureOpenAI instantiation in agents.
#
# 1. Copy this file: cp .env.example .env
# 2. Set AZURE_OPENAI_* variables below
# 3. Fill in your GitHub token for PR creation
# 4. Run: make demo

# =============================================================================
# LLM Configuration (v4.2 factory pattern)
# =============================================================================
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-azure-openai-key-here
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-ada-002

# =============================================================================
# Legacy Universal LLM (DEPRECATED — use AZURE_OPENAI_* above instead)
# Kept for backward compatibility only.
# =============================================================================
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-v1-...
# LLM_MODEL=openai/gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# Azure OpenAI Direct (DEPRECATED — use factory pattern above instead)
# Legacy variables kept for backward compatibility only.
# Note: Use AZURE_OPENAI_KEY (not AZURE_OPENAI_API_KEY)
# =============================================================================
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_KEY=your-azure-openai-key-here (legacy name: AZURE_OPENAI_API_KEY)
# AZURE_OPENAI_DEPLOYMENT=gpt-4
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# =============================================================================
# PostgreSQL Database (Azure-compatible - uses PostgreSQL instead of Redis)
# =============================================================================
# For local Docker:
DATABASE_URL=postgres://iterateswarm:iterateswarm@localhost:5432/iterateswarm?sslmode=disable

# For Azure PostgreSQL:
# DATABASE_URL=postgres://username:password@your-server.postgres.database.azure.com:5432/iterateswarm?sslmode=require

# =============================================================================
# Infrastructure (Docker defaults - usually no changes needed)
# =============================================================================
REDPANDA_BROKERS=localhost:9094
TEMPORAL_HOST=localhost:7233
QDRANT_URL=http://localhost:6333

# =============================================================================
# Consumer Configuration (for Redpanda -> Temporal integration)
# =============================================================================
KAFKA_BROKERS=redpanda:9092
TEMPORAL_ADDRESS=temporal:7233

# =============================================================================
# GitHub (REQUIRED for SWE and Reviewer agents)
# Get token from: https://github.com/settings/tokens
# Required scopes: repo, workflow, write:discussion
# =============================================================================
GITHUB_TOKEN=your-github-token-here
GITHUB_OWNER=your-github-username-or-org
GITHUB_REPO=your-repo-name

# =============================================================================
# Observability (Optional - for local development)
# =============================================================================
SIGNOZ_URL=http://localhost:3301
HYPERDX_URL=http://localhost:8090
OTEL_ENDPOINT=http://localhost:4317

# =============================================================================
# Optional Integrations
# =============================================================================

# Discord Bot (for ChatOps)
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=

# Slack App (for ChatOps)
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# Sentry (for error tracking)
SENTRY_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Langfuse (for LLM observability)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# JWT Authentication (for admin panel - GitHub OAuth)
JWT_SECRET=super_secret_dev_key_replace_in_prod_with_random_string
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
APP_URL=http://localhost:3000

# =============================================================================
# Development & Test Mode
# =============================================================================
# DEV_MODE: enables detailed logging and debug endpoints
DEV_MODE=true
# TEST_MODE: enables test-only features and relaxed security
TEST_MODE=true

# =============================================================================
# Agent Configuration (optional - has sensible defaults)
# =============================================================================

# Token budget per task (default: 50000)
MAX_TOKENS_PER_TASK=50000

# Max concurrent agent tasks (default: 3)
MAX_CONCURRENT_TASKS=3

# Context window management
CONTEXT_WINDOW_MAX_TOKENS=80000
CONTEXT_WINDOW_KEEP_LAST_N=5

# =============================================================================
# ARCHITECTURE NOTES
# =============================================================================
# This version uses PostgreSQL for ALL state management:
#   - Idempotency keys (was Redis SETNX)
#   - Token budgets (was Redis INCRBY)
#   - Agent context (was Redis shared state)
#   - HITL queue (was Redis pending queue)
#   - Agent events (was Redis Pub/Sub -> now PostgreSQL LISTEN/NOTIFY)
#
# Benefits:
#   - Single database for all state (simpler ops)
#   - Works with Azure free PostgreSQL tier
#   - No Redis dependency (saves cost)
#   - ACID transactions across all operations
#
# Migration: Run apps/core/migrations/002_replace_redis.sql on your database

# Neo4j / Graphiti (Saarathi Memory Layer)
NEO4J_URI=bolt://saarathi-neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=saarathi

# =============================================================================
# Sandbox (Saarathi - Isolated Python Execution for Charts/Computation)
# =============================================================================
SANDBOX_URL=http://saarathi-sandbox:5000
SANDBOX_SECRET=change-in-production
