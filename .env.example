# IterateSwarm OS - Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git!

# =============================================================================
# Azure OpenAI (REQUIRED for all AI agents)
# =============================================================================
AZURE_OPENAI_ENDPOINT=https://aparnaopenai.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-oss-120b
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# =============================================================================
# Infrastructure (Docker defaults - usually no changes needed)
# =============================================================================
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgres://iterateswarm:iterateswarm@localhost:5433/iterateswarm
REDPANDA_BROKERS=localhost:9094
TEMPORAL_HOST=localhost:7233
QDRANT_URL=http://localhost:6333

# =============================================================================
# GitHub (REQUIRED for SWE and Reviewer agents)
# Get token from: https://github.com/settings/tokens
# =============================================================================
GITHUB_TOKEN=your-github-token-here
GITHUB_OWNER=your-github-username-or-org
GITHUB_REPO=your-repo-name

# =============================================================================
# Observability
# =============================================================================
SIGNOZ_URL=http://localhost:3301
HYPERDX_URL=http://localhost:8090
OTEL_ENDPOINT=http://localhost:4317

# =============================================================================
# Optional Integrations
# =============================================================================

# Discord Bot (for ChatOps)
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=

# Slack App (for ChatOps)
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# Sentry (for error tracking)
SENTRY_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Langfuse (for LLM observability)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# JWT Authentication (for admin panel - GitHub OAuth)
JWT_SECRET=super_secret_dev_key_replace_in_prod
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
APP_URL=http://localhost:3000

# Development & Test Mode (set to true for E2E tests)
DEV_MODE=true
TEST_MODE=true

# Deprecated: Clerk Auth (no longer used - kept for backward compatibility)
# CLERK_SECRET_KEY=
# CLERK_PUBLISHABLE_KEY=
# CLERK_INSTANCE_ID=

# =============================================================================
# Agent Configuration (optional - has defaults)
# =============================================================================

# Token budget settings
MAX_TOKENS_PER_TASK=50000
MAX_CONCURRENT_TASKS=3

# Context window settings
CONTEXT_WINDOW_MAX_TOKENS=80000
CONTEXT_WINDOW_KEEP_LAST_N=5
