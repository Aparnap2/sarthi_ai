      "responses": [
        {
          "uuid": "resp-health-ok",
          "label": "Healthy",
          "statusCode": 200,
          "latency": 0,
          "body": "{\"status\": \"ok\", \"service\": \"sarthi-mockoon\"}",
          "headers": [{"key": "Content-Type", "value": "application/json"}]
        }
      ],
      "enabled": true,
      "type": "http"
