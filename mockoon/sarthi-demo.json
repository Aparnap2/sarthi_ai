      "endpoint": "slack/deliver",
      "responses": [
        {
          "uuid": "resp-slack-deliver-ok",
          "label": "Slack delivery accepted",
          "statusCode": 200,
          "latency": 80,
          "body": "{\"ok\": true, \"ts\": \"{{now 'x'}}\", \"channel\": \"C_NOVAPULSE_DEMO\"}",
          "headers": [{"key": "Content-Type", "value": "application/json"}]
        }
      ],
      "enabled": true,
      "type": "http"
    },
    {
      "uuid": "route-slack-chat-postmessage",
      "documentation": "Slack API postMessage — captured for assertion",
      "method": "post",
      "endpoint": "api/chat.postMessage",
      "responses": [
        {
          "uuid": "resp-slack-post-ok",
          "label": "Slack postMessage OK",
          "statusCode": 200,
          "latency": 120,
          "body": "{\"ok\": true, \"channel\": \"C_NOVAPULSE_DEMO\", \"ts\": \"{{now 'x'}}\"}",
          "headers": [{"key": "Content-Type", "value": "application/json"}]
        }
      ],
      "enabled": true,
      "type": "http"
    },
    {
      "uuid": "route-stripe-webhook",
      "documentation": "Synthetic Stripe webhook — payment_intent.payment_failed",
      "method": "post",
      "endpoint": "simulate/stripe-webhook",
      "responses": [
        {
          "uuid": "resp-stripe-webhook-ok",
          "label": "Webhook forwarded",
          "statusCode": 200,
          "latency": 50,
